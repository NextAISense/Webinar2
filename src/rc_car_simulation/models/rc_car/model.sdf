<?xml version="1.0" ?>
<sdf version='1.7'>
  <model name='rc_car'>
   
    <link name="base_footprint">
    </link>
    <link name='base_link'>      
      <must_be_base_link>true</must_be_base_link>
      <inertial>
        <pose>-5.5136999999999997e-05 0.64776999999999996 0.10824 0 0 0</pose>
        <mass>11.858000000000001</mass>
        <inertia>
          <ixx>1.8393999999999999</ixx>
          <ixy>-0.00040467999999999998</ixy>
          <ixz>6.3267000000000003e-05</ixz>
          <iyy>0.63368000000000002</iyy>
          <iyz>-0.0045383999999999997</iyz>
          <izz>2.4211999999999998</izz>
        </inertia>
      </inertial>
      <collision name='chasis_collision'>
        <pose>0 0 0 0 0 1.570796</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>meshes/base_link.STL</uri>
          </mesh>
        </geometry>
      </collision>
      <visual name='chasis_visual'>
        <pose>0 0 0 0 0 1.570796</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>meshes/base_link.STL</uri>
          </mesh>
        </geometry>
        <material>
          <diffuse>0.0 0.6 0.9 1</diffuse>          <!-- Bright cyan -->
          <ambient>0.0 0.2 0.3 1</ambient>          <!-- Dimmer version to give depth -->
          <specular>0.8 0.9 1.0 1</specular>        <!-- Strong light response -->
          <emissive>0.02 0.05 0.1 1</emissive>
        </material>
      </visual>
    </link>

    <link name="camera_link">
      <pose relative_to='camera_joint'>0 0 0.025 0 0 0</pose>
      <sensor name='camera_sensor' type='camera'>
        <pose>0.09 0 0 0 0 0</pose>
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.01</near>
            <far>100</far>
          </clip>
        </camera>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <visualize>true</visualize>
        <!-- <topic>camera</topic> -->
      </sensor>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.000166667</ixx>
          <iyy>0.000166667</iyy>
          <izz>0.000166667</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <box>
            <size>0.18 0.3 0.05</size>
          </box>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <box>
            <size>0.18 0.3 0.05</size>
          </box>
        </geometry>
        <material>
          <diffuse>0.1 0.3 0.8 1</diffuse>         Metallic blue
          <ambient>0.1 0.1 0.2 1</ambient>
          <specular>0.5 0.5 0.5 1</specular>       Reflective
          <emissive>0 0 0 1</emissive>
        </material>
      </visual>
    </link>
    <link name='lidar_link'>
      <pose relative_to='lidar_joint'>0 0 0.05 0 0 0</pose>
      <sensor name='gpu_lidar' type='gpu_lidar'>"
        <pose>0 0 0 0 0 0</pose>
        <!-- <topic>lidar</topic> -->
        <gz_frame_id>lidar_link</gz_frame_id>
        <update_rate>10</update_rate>
        <ray>
            <scan>
                <horizontal>
                    <samples>640</samples>
                    <resolution>1</resolution>
                    <min_angle>-3.141592653589793</min_angle>
                    <max_angle>3.141592653589793</max_angle>
                </horizontal>
                <vertical>
                    <samples>1</samples>
                    <resolution>0.01</resolution>
                    <min_angle>0</min_angle>
                    <max_angle>0</max_angle>
                </vertical>
            </scan>
            <range>
                <min>0.08</min>
                <max>10.0</max>
                <resolution>0.01</resolution>
            </range>
            <noise>
              <type>gaussian</type>
              <mean>0.0</mean>
              <stddev>0.001</stddev>
            </noise>
        </ray>
        <always_on>1</always_on>
        <visualize>true</visualize>
      </sensor>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.000145833</ixx>
          <iyy>0.000145833</iyy>
          <izz>0.000125</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.1</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.05</radius>
            <length>0.1</length>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0.8 0.3 0.1 1</diffuse>
          <ambient>0.2 0.1 0.05 1</ambient>
          <specular>0.5 0.5 0.5 1</specular>
          <emissive>0 0 0 1</emissive>
        </material>
      </visual>
    </link>

    <link name='imu_link'>
      <pose relative_to='imu_joint'>0 0 0.0025 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>2.08333e-07</ixx>
          <iyy>2.08333e-07</iyy>
          <izz>2.08333e-07</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <box>
            <size>0.005 0.005 0.005</size>
          </box>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <box>
            <size>0.005 0.005 0.005</size>
          </box>
        </geometry>
        <material>
          <diffuse>0.9 0.9 0.1 1</diffuse>
          <ambient>0.3 0.3 0.05 1</ambient>
          <specular>0.5 0.5 0.5 1</specular>
          <emissive>0 0 0 1</emissive>
        </material>
      </visual>
      <sensor name='imu_sensor' type='imu'>
        <always_on>1</always_on>
        <update_rate>100</update_rate>
        <visualize>true</visualize>
        <gz_frame_id>imu_link</gz_frame_id>
        <!-- <topic>imu/data</topic> -->
        <imu>
          <angular_velocity>
            <x>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>2e-4</stddev>
                <bias_mean>0.0000075</bias_mean>
                <bias_stddev>0.0000008</bias_stddev>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>2e-4</stddev>
                <bias_mean>0.0000075</bias_mean>
                <bias_stddev>0.0000008</bias_stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>2e-4</stddev>
                <bias_mean>0.0000075</bias_mean>
                <bias_stddev>0.0000008</bias_stddev>
              </noise>
            </z>
          </angular_velocity>
          <linear_acceleration>
            <x>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>1.7e-2</stddev>
                <bias_mean>0.1</bias_mean>
                <bias_stddev>0.001</bias_stddev>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>1.7e-2</stddev>
                <bias_mean>0.1</bias_mean>
                <bias_stddev>0.001</bias_stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>1.7e-2</stddev>
                <bias_mean>0.1</bias_mean>
                <bias_stddev>0.001</bias_stddev>
              </noise>
            </z>
          </linear_acceleration>
        </imu>
      </sensor>
    </link>
